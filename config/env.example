# TrendCut Studio public environment template
# Copy this file to .env and fill only the providers/features you actually use.

# BFF / FastAPI
BFF_PORT=3002
BFF_HOST=127.0.0.1
FASTAPI_BASE_URL=http://127.0.0.1:8000
INTERNAL_API_TOKEN=dev-internal-token
BFF_API_TOKEN=
BFF_ROLES=admin

# Core workflow
COMFYUI_BASE_URL=http://127.0.0.1:8188
LLM_PROVIDER=qwen
TEXT_LLM_PROVIDER=qwen

# Qwen / DashScope
# Used by the default public template for text, vision, ASR, and review workflows.
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ASR_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_TEXT_MODEL=qwen-plus
QWEN_VL_MODEL=qwen-vl-plus
QWEN_ASR_MODEL=paraformer-v2

# Hotspot discovery
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast

# Agent API / MCP bridge
# MCP now talks to the NestJS BFF. Use BFF_API_TOKEN or BFF_API_KEYS for access.
AGENT_ENABLE_REAL_PUBLISH=false

# AI review
AI_REVIEW_ENABLED=true
AI_REVIEW_REQUIRE_MANUAL_CONFIRM=true

# Optional digital-human provider
RUNNINGHUB_API_KEY=
RUNNINGHUB_WORKFLOW_ID=

# Optional notification and login checks
FEISHU_WEBHOOK_URL=
LOGIN_CHECK_ENABLED=false
LOGIN_CHECK_INTERVAL_MINUTES=120

# Optional publishing safeguards
AUTO_ARCHIVE_PUBLISHED=true
AUTO_CLEANUP_ENABLED=true
AUTO_CLEANUP_DRY_RUN=false
